---
import { iconPaths, type IconName } from "../lib/icons";

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className = "h-4 w-4" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d={iconPaths[name]} />
</svg>
