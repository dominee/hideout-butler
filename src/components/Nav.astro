---
import Icon from "./Icon.astro";

const appUrl = "https://app.hideoutbutler.com";
const githubUrl = "https://github.com/dominee/PoE2-butler";

const navLinks = [
  { href: "#how-it-works", label: "How it works" },
  { href: "#features", label: "Features" },
  { href: "#screenshots", label: "Screenshots" },
  { href: "#privacy", label: "Privacy" },
  { href: "#limitations", label: "Limitations" },
  { href: "#faq", label: "FAQ" },
];
---

<header
  class="sticky top-0 z-50 border-b border-ink-700/80 bg-ink-950/90 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <a
      href="#"
      class="inline-flex items-center gap-2 font-display text-lg font-semibold tracking-wide text-parchment-50 transition hover:text-ember-400 sm:text-xl"
    >
      <img src="/favicon.svg" alt="" class="h-7 w-7" width="28" height="28" />
      Hideout Butler
    </a>

    <ul class="hidden items-center gap-5 lg:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-parchment-200/90 transition hover:text-ember-400"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-md p-2 text-parchment-200 transition hover:bg-ink-800 hover:text-ember-400 sm:inline-flex"
        aria-label="View on GitHub"
      >
        <Icon name="github" class="h-5 w-5" />
      </a>
      <a href={appUrl} class="btn-primary gap-2 text-xs sm:text-sm">
        <Icon name="external" class="h-4 w-4" />
        Open App
      </a>
    </div>
  </nav>
</header>
