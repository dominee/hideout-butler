      },
      {
        title: "Exact tolerance + Save",
        summary: "Per-user trade search tolerance.",
        body: "Set the percentage band for exact-match searches; persisted for later use.",
      },
      {
        title: "Trade Search",
        summary: "Opens official PoE2 trade with your stats.",
        body: "Submits a search from the item using your saved tolerance — search JSON copied to clipboard.",
      },
      {
        title: "Upgrade",
        summary: "Min-floor upgrade search (~95% of current rolls).",
        body: "Find strictly better versions on the same base with floor values per stat.",
      },
      {
        title: "Upgrade (weighted)",
        summary: "Prioritises highest-tier mods.",
        body: "Falls back to regular upgrade when GGG rejects weighted queries from server-side callers.",
      },
    ],
  },
  {
    id: "stash",
    label: "Stash view",
    icon: "grid",
    src: "/screenshots/stash.webp",
    width: 430,
    height: 434,
    alt: "Stash tab icon grid with valuable item highlights",
    kind: "stash",
    intro: "Stash tab features in icon grid view (demo/dev until GGG stash scope ships).",
    callouts: [
      {
        title: "Icon grid layout",
        summary: "PoE CDN icons with correct cell footprints.",
        body: "1×1 rings up to 2×4 weapons — fixed grid matching in-game tab geometry.",
      },
      {
        title: "Valuable highlights",
        summary: "Gold outline above your chaos threshold.",
        body: "High-value drops stand out in a full tab without opening each cell.",
      },
      {
        title: "Activity indicators",
        summary: "Green = new, amber = changed.",
        body: "Driven by the activity log diff since your last refresh.",
      },
      {
        title: "Grid & table modes",
        summary: "Switch views per tab.",
        body: "Sortable table alternative with filter and layout preferences that persist.",
      },
    ],
  },
];

function slideItems(slide: ShowcaseSlide): (Callout | MenuFeature)[] {
  return slide.features ?? slide.callouts ?? [];
}

function slideHeading(slide: ShowcaseSlide): string {
  if (slide.kind === "menu") return "Item action menu";
  return slide.label;
}
---

<section id="screenshots" class="section-divider border-b border-ink-800 bg-ink-950 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="section-heading">Screenshots</h2>
      <p class="section-subheading">
        A glimpse of the app in action — dark PoE-inspired UI with analytical
        depth beneath every item.
      </p>
    </div>

    <div class="mt-10" data-screenshot-showcase>
      <div
        class="flex flex-wrap gap-2"
        role="tablist"
        aria-label="Screenshot gallery"
      >
        {
          slides.map((slide, index) => (
            <button
              type="button"
              role="tab"
              id={`tab-${slide.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${slide.id}`}
              data-screenshot-tab={slide.id}
              class:list={[
                "inline-flex items-center gap-2 rounded-md border border-l-4 border-ink-600 bg-ink-900/60 px-3 py-2 text-sm font-medium text-parchment-200/90 transition hover:border-ember-500/40 hover:text-ember-400 aria-selected:border-ember-500/50 aria-selected:bg-ember-500/10 aria-selected:text-ember-400",
                slide.tabAccent,
              ]}
            >
              <Icon name={slide.icon} class="h-4 w-4 shrink-0" />
              {slide.label}
            </button>
          ))
        }
      </div>

      <div class="mt-8">
        {
          slides.map((slide, index) => (
            <div
              id={`panel-${slide.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${slide.id}`}
              data-screenshot-panel={slide.id}
              tabindex={index === 0 ? 0 : -1}
              hidden={index !== 0}
            >
              <div class="card-pane grid gap-8 overflow-hidden p-4 sm:p-6 lg:grid-cols-[minmax(0,380px)_1fr] lg:items-start lg:gap-10">
                <figure
                  class:list={[
                    "mx-auto w-full lg:mx-0 lg:sticky lg:top-24",
                    slide.kind === "wide" ? "max-w-3xl" : "max-w-[380px]",
                    slide.figureClass,
                  ]}
                >
                  <img
                    src={slide.src}
                    alt={slide.alt}
                    width={slide.width}
                    height={slide.height}
                    class:list={[
                      "w-full rounded-md border border-ink-600/60",
                      slide.imageClass,
                    ]}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </figure>

                <div class="min-w-0">
                  <h3 class="font-display text-lg font-semibold text-parchment-50">
                    {slideHeading(slide)}
                  </h3>
                  {slide.intro && (
                    <p class="mt-2 text-sm text-parchment-200/85">{slide.intro}</p>
                  )}
                  <ul class="mt-6 space-y-5">
                    {slideItems(slide).map((item) => (
                      <li class="border-l-2 border-ember-500/50 pl-4">
                        <h4 class="text-sm font-semibold text-ember-400">
                          {item.title}
                        </h4>
                        {"summary" in item && item.summary && (
                          <p class="mt-1 text-sm font-medium text-parchment-100/90">
                            {item.summary}
                          </p>
                        )}
                        <p class="mt-1 text-sm leading-relaxed text-parchment-200/85">
                          {item.body}
                        </p>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initScreenshotShowcase() {
    document.querySelectorAll("[data-screenshot-showcase]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.showcaseBound === "true") return;
      root.dataset.showcaseBound = "true";

      const tabs = root.querySelectorAll("[data-screenshot-tab]");
      const panels = root.querySelectorAll("[data-screenshot-panel]");

      const activate = (id: string, focusPanel = false) => {
        tabs.forEach((tab) => {
          const selected = tab.getAttribute("data-screenshot-tab") === id;
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel) => {
          const active = panel.getAttribute("data-screenshot-panel") === id;
          panel.hidden = !active;
          panel.setAttribute("tabindex", active ? "0" : "-1");
          if (active && focusPanel && panel instanceof HTMLElement) {
            panel.focus({ preventScroll: true });
          }
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const id = tab.getAttribute("data-screenshot-tab");
          if (id) activate(id, true);
        });
      });
    });
  }

  initScreenshotShowcase();
  document.addEventListener("astro:page-load", initScreenshotShowcase);
</script>

<style>
  [role="tabpanel"]:focus {
    outline: none;
  }

  [role="tabpanel"]:focus-visible {
    outline: 2px solid rgba(200, 160, 64, 0.5);
    outline-offset: 4px;
    border-radius: 0.5rem;
  }
</style>
