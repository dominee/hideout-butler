        summary: "Compact alternative available.",
        body: "Choose Simple for a shorter overview card when you do not need every mod line.",
      },
      {
        title: "Historic snapshots",
        summary: "Export what you saw on a past date.",
        body: "Select a timeline dot first — the PNG matches that historic gear state.",
      },
    ],
  },
  {
    id: "rare-detail",
    label: "Rare item detail",
    icon: "chart",
    src: "/screenshots/item-6ccf44f0-detail.webp",
    width: 800,
    height: 2318,
    alt: "Rare weapon item detail export showing mod tiers and roll quality bars",
