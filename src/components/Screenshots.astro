---
import Icon from "./Icon.astro";
import type { IconName } from "../lib/icons";

type Callout = {
  title: string;
  summary?: string;
  body: string;
};

type MenuFeature = {
  title: string;
  summary?: string;
  body: string;
};

type ShowcaseSlide = {
  id: string;
  label: string;
  icon: IconName;
  src: string;
  width: number;
  height: number;
  alt: string;
  kind: "annotated" | "menu" | "stash" | "wide";
  tabAccent?: string;
  intro?: string;
  callouts?: Callout[];
  features?: MenuFeature[];
  imageClass?: string;
  figureClass?: string;
};

const slides: ShowcaseSlide[] = [
  {
    id: "main-ui",
    label: "Main UI",
    icon: "monitor",
    src: "/screenshots/Screenshot.webp",
    width: 2498,
    height: 1280,
    alt: "Hideout Butler main screen showing gear timeline, character gear, stat summary, and item detail pane",
    kind: "annotated",
    intro: "The primary app layout — gear timeline, live GGG character gear, stats, activity, and item detail.",
    callouts: [
      {
        title: "Gear snapshot timeline",
        summary: "Browse historic equipped gear after each change.",
        body: "Dots appear only when items are added, removed, or modified. Click a dot for that snapshot's doll, table, stats, and item detail — Back to current when done.",
      },
      {
        title: "Activity log",
        summary: "Track what changed since your last refresh.",
        body: "Collapsible sidebar lists new, changed, and removed items across stash tabs and equipped gear. Refresh once to establish a baseline, then spot diffs on the next pull.",
      },
      {
        title: "Stat summary",
        summary: "Equipment stats with T1 quality bars per section.",
        body: "Life, resistances, attributes, and other grouped stats with brief and expanded views — see how well your current gear rolls without adding each piece manually.",
      },
      {
        title: "Character gear grid",
        summary: "Doll or table view of equipped items.",
        body: "Switch layouts, select any piece, and open the detail pane. League selector and Refresh in the header keep the snapshot aligned with your chosen league.",
      },
      {
        title: "Item detail pane",
        summary: "Full mod breakdown, pricing, and actions.",
        body: "Trade search, share links, image export, and roll quality bars live here — the hub for inspecting a single item in depth.",
      },
      {
        title: "Share or export character",
        summary: "Public character links and PNG exports.",
        body: "Create simple or detailed share URLs — including historic timeline snapshots — or export a Discord-ready PNG of the full build.",
      },
    ],
  },
  {
    id: "gear-timeline",
    label: "Gear timeline",
    icon: "activity",
    src: "/screenshots/Timeline.webp",
    width: 1318,
    height: 298,
    alt: "Gear snapshot timeline with change dots, diff list, and Back to current",
    kind: "wide",
    intro: "Timeline detail — each dot is a gear change event with a readable diff.",
    callouts: [
      {
        title: "Change dots",
        summary: "One dot per meaningful gear update.",
        body: "Unchanged refreshes are not stored. Up to 20 events per character are retained for browsing.",
      },
      {
        title: "Diff labels",
        summary: "+ new, ~ changed, − removed.",
        body: "See exactly what swapped when — e.g. Mageblood added, Headhunter removed — before opening the historic doll view.",
      },
      {
        title: "Historic browsing",
        summary: "Full app state at that moment.",
        body: "Stat summary, doll/table layouts, and item detail reflect the selected snapshot. An amber banner marks historic view.",
      },
