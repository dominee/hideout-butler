---
import Icon from "./Icon.astro";
import type { IconName } from "../lib/icons";

type Callout = {
  title: string;
  body: string;
};

type MenuFeature = {
  title: string;
  body: string;
};

type ShowcaseSlide = {
  id: string;
  label: string;
  icon: IconName;
  src: string;
  alt: string;
  kind: "annotated" | "menu" | "stash";
  intro?: string;
  callouts?: Callout[];
  features?: MenuFeature[];
};

const slides: ShowcaseSlide[] = [
  {
    id: "rare-detail",
    label: "Rare item detail",
    icon: "chart",
    src: "/screenshots/item-6ccf44f0-detail.png",
    alt: "Rare weapon item detail export showing mod tiers and roll quality bars",
    kind: "annotated",
    intro: "Sections top to bottom as shown in the detail export PNG.",
    callouts: [
      {
        title: "Detail image export",
        body: "This screenshot is the client-generated PNG from Image (detail) — a self-contained share card you can post to Discord, forums, or trade chats. It captures the item name, rarity, pricing, score, socketed runes, and full mod breakdown without requiring viewers to open the app.",
      },
      {
        title: "Pricing",
        body: "Hybrid market estimate in divine and exalted orbs. Bulk values come from poe.ninja; you can request a refined snapshot from the GGG trade API on demand. Numbers are labelled indicative — useful for comparing drops, not a live market guarantee.",
      },
      {
        title: "Item score",
        body: "Aggregate roll quality across all rated explicit mods, expressed as a percentage bar. Here the crossbow scores 116% — a quick read on whether the item is merely usable or genuinely well rolled before you dive into individual mods.",
      },
      {
        title: "Runes & cores",
        body: "Every socketed rune and soul core is parsed and listed with its effect text for martial weapons, wands, armour, or boots as applicable. You see exactly what each socket contributes without hovering in-game or cross-referencing wiki pages.",
      },
      {
        title: "Prefix rolls & spreads",
        body: "Each prefix shows its tier label (e.g. T2 of 8), the rolled value, the numeric range for that tier, the T1 cap, required item level, and a roll rating bar with percentage. Compare 163% phys at 91% of range versus +5 attack skills pinned at 100% — spot which mods carry the item.",
      },
      {
        title: "Suffix rolls & spreads",
        body: "Suffixes use the same tier, range, and roll-rating breakdown as prefixes. Life leech at T1/4 with a 94% roll is easy to scan; a 100% onslaught suffix tells you that mod is perfect. Together with prefixes, this is the full stat spread picture for trade or keep decisions.",
      },
    ],
  },
  {
    id: "unique-detail",
    label: "Unique item detail",
    icon: "star",
    src: "/screenshots/item-74538585-detail.png",
    alt: "Unique item detail export with flavour text and explicit mods",
    kind: "annotated",
    intro: "Sections top to bottom as shown in the unique item detail export.",
    callouts: [
      {
        title: "Pricing",
        body: "Estimated value for uniques uses the same hybrid pricing pipeline — shown inline next to the item header.",
      },
      {
        title: "Item quality",
        body: "Overall quality score for variable unique rolls, summarised as a single percentage bar across rated mods.",
      },
      {
        title: "Implicit roll spreads",
        body: "Implicit mods show their possible range (e.g. 20–30% stun threshold) plus a type-quality bar rating the current roll within that spread.",
      },
      {
        title: "Unique mod rolls",
        body: "Variable unique stats (+Life, +Str, +Dex, etc.) display min–max spreads and per-mod type-quality ratings — spot a well-rolled Headhunter at a glance.",
      },
      {
        title: "Fixed unique effect",
        body: "Static unique text (non-variable) is shown verbatim below the rated mods — the signature modifier that defines the item.",
      },
    ],
  },
  {
    id: "item-menu",
    label: "Item actions",
    icon: "menu",
    src: "/screenshots/item_detail_menu.png",
    alt: "Item detail action menu with share, export, trade search, and upgrade buttons",
    kind: "menu",
    intro: "Tools available from the item detail pane — top to bottom as shown in the screenshot.",
    features: [
      {
        title: "Create & copy link",
        body: "Generate a public read-only page for this item snapshot — no GGG account or app login required for viewers.",
      },
      {
        title: "Image / Image (detail)",
        body: "Export Discord-ready PNGs: a compact card or a full detail layout with tiers, ranges, and roll bars.",
      },
      {
        title: "Copy PoE2 item text",
        body: "Copy the item as PoE2-style clipboard text for pasting into trade tools or build planners.",
      },
      {
        title: "Exact tolerance + Save",
        body: "Set the percentage tolerance used for exact-match trade searches; saved per user for later searches.",
      },
      {
        title: "Trade Search",
        body: "Submit a trade-site search from the item's stats using your saved tolerance — opens results on the official PoE2 trade site.",
      },
      {
        title: "Upgrade",
        body: "Search for upgrades with min-floor rolls at ~95% of your current values on each stat.",
      },
      {
        title: "Upgrade (weighted)",
        body: "Prioritise your highest-tier mods when searching for upgrades. Falls back to regular upgrade when GGG rejects weighted queries.",
      },
    ],
  },
  {
    id: "stash",
    label: "Stash view",
    icon: "grid",
    src: "/screenshots/stash.png",
    alt: "Stash tab icon grid with valuable item highlights",
    kind: "stash",
    intro: "Stash tab features as shown in the icon grid view.",
    callouts: [
      {
        title: "Icon grid layout",
        body: "Items render in a fixed grid using PoE CDN icons, respecting each item's cell footprint (1×1 rings up to 2×4 weapons).",
      },
      {
        title: "Valuable highlights",
        body: "Items at or above your chaos threshold get a gold outline so high-value drops stand out in a full tab.",
      },
      {
        title: "Activity indicators",
        body: "New items show a green dot; changed items an amber dot — driven by the activity log diff since your last refresh.",
      },
      {
        title: "Grid & table modes",
        body: "Switch between icon grid and sortable table views; filter and layout preferences persist per tab.",
      },
    ],
  },
];

function slideItems(slide: ShowcaseSlide): Callout[] {
  return slide.features ?? slide.callouts ?? [];
}

function slideHeading(slide: ShowcaseSlide): string {
  if (slide.kind === "menu") return "Item action menu";
  return slide.label;
}
---

<section id="screenshots" class="border-b border-ink-800 bg-ink-950 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="section-heading">Screenshots</h2>
      <p class="section-subheading">
        A glimpse of the app in action — dark PoE-inspired UI with analytical
        depth beneath every item.
      </p>
    </div>

    <div class="mt-10" data-screenshot-showcase>
      <div
        class="flex flex-wrap gap-2"
        role="tablist"
        aria-label="Screenshot gallery"
      >
        {
          slides.map((slide, index) => (
            <button
              type="button"
              role="tab"
              id={`tab-${slide.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${slide.id}`}
              data-screenshot-tab={slide.id}
              class="inline-flex items-center gap-2 rounded-md border border-ink-600 bg-ink-900/60 px-3 py-2 text-sm font-medium text-parchment-200/90 transition hover:border-ember-500/40 hover:text-ember-400 aria-selected:border-ember-500/50 aria-selected:bg-ember-500/10 aria-selected:text-ember-400"
            >
              <Icon name={slide.icon} class="h-4 w-4 shrink-0" />
              {slide.label}
            </button>
          ))
        }
      </div>

      <div class="mt-8">
        {
          slides.map((slide, index) => (
            <div
              id={`panel-${slide.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${slide.id}`}
              data-screenshot-panel={slide.id}
              hidden={index !== 0}
            >
              <div class="card-pane grid gap-8 overflow-hidden p-4 sm:p-6 lg:grid-cols-[minmax(0,380px)_1fr] lg:items-start lg:gap-10">
                <figure class="mx-auto w-full max-w-[380px] lg:mx-0 lg:sticky lg:top-24">
                  <img
                    src={slide.src}
                    alt={slide.alt}
                    width="800"
                    height="600"
                    class="w-full rounded-md border border-ink-600/60"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </figure>

                <div class="min-w-0">
                  <h3 class="font-display text-lg font-semibold text-parchment-50">
                    {slideHeading(slide)}
                  </h3>
                  {slide.intro && (
                    <p class="mt-2 text-sm text-parchment-200/75">{slide.intro}</p>
                  )}
                  <ul class="mt-6 space-y-5">
                    {slideItems(slide).map((item) => (
                      <li class="screenshot-callout border-l-2 border-ember-500/50 pl-4">
                        <h4 class="text-sm font-semibold text-ember-400">
                          {item.title}
                        </h4>
                        <p class="mt-1 text-sm leading-relaxed text-parchment-200/80">
                          {item.body}
                        </p>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initScreenshotShowcase() {
    document.querySelectorAll("[data-screenshot-showcase]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.showcaseBound === "true") return;
      root.dataset.showcaseBound = "true";

      const tabs = root.querySelectorAll("[data-screenshot-tab]");
      const panels = root.querySelectorAll("[data-screenshot-panel]");

      const activate = (id: string) => {
        tabs.forEach((tab) => {
          const selected = tab.getAttribute("data-screenshot-tab") === id;
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel) => {
          const active = panel.getAttribute("data-screenshot-panel") === id;
          panel.hidden = !active;
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const id = tab.getAttribute("data-screenshot-tab");
          if (id) activate(id);
        });
      });
    });
  }

  initScreenshotShowcase();
  document.addEventListener("astro:page-load", initScreenshotShowcase);
</script>
