{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hideout-butler",
  "compatibility_date": "2025-05-21",
  "main": "./dist/_worker.js/index.js",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
